# Copy this file to .env and edit values for your deployment.

# Long random string used to sign login tokens. CHANGE THIS.
SECRET_KEY=change-me-in-production-please-use-a-long-random-string

# How long a login stays valid (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database (SQLite file by default; swap for Postgres etc. later)
DATABASE_URL=sqlite:///./pinkman.db

# Which frontend origins are allowed to call this API.
# Put your Netlify URL here in production, e.g. https://your-site.netlify.app
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Default admin account created on first run
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123
